generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters", "multiSchema"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
  // Domain-organised schemas — nothing lives in `public` anymore.
  schemas   = ["identity", "catalog", "ops", "billing", "audit"]
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT  — the brand / company entity (e.g. "ABC Pharmacy")
// Virtual — has no physical address; branches do.
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id               String           @id @default(cuid())
  name             String           // "ABC Pharmacy"  (display name)
  legalName        String?          // registered legal entity name
  slug             String           @unique // "abc-pharmacy"
  registrationNo   String?          @unique // business registration number
  taxId            String?          // VAT / TIN
  businessType     String           @default("sole_proprietorship") // sole_proprietorship | partnership | pvt_ltd | plc
  logoUrl          String?
  website          String?
  email            String?          // primary contact email
  phone            String?          // primary contact phone
  addressLine1     String?
  addressLine2     String?
  city             String?
  district         String?
  province         String?
  postalCode       String?
  isActive         Boolean          @default(true)
  isVerified       Boolean          @default(false)
  subscriptionPlan String           @default("free") // free | basic | professional | enterprise
  subscriptionExpiry DateTime?
  notes            String?          // internal admin notes
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  branches    PharmacyBranch[]
  users       User[]           // pharmacy_admin + pharmacy_staff under this tenant
  owner       TenantOwner?
  contacts    TenantContact[]
  documents   TenantDocument[]
  roles       Role[]           // custom roles owned by this tenant

  @@schema("identity")
}

// ─────────────────────────────────────────────────────────────────────────────
// PHARMACY BRANCH  — a real physical location (e.g. "ABC Colombo")
// system_admin creates branches; pharmacy_admin can view/manage their own.
// ─────────────────────────────────────────────────────────────────────────────

model PharmacyBranch {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  name            String   // "ABC Colombo"  (display name for this branch)
  branchCode      String?  // internal code e.g. "COL-001"
  address         String
  addressLine2    String?
  city            String
  district        String?
  province        String?
  postalCode      String?
  phone           String
  email           String?
  licenseNo       String   @unique // each branch has its own pharmacy license
  licenseExpiry   DateTime?
  pharmacistName  String?  // chief pharmacist
  pharmacistRegNo String?  // pharmacist SLMC registration number
  latitude        Float?
  longitude       Float?
  openingTime     String?  // "08:00"
  closingTime     String?  // "21:00"
  isOpen24h       Boolean  @default(false)
  isMainBranch    Boolean  @default(false) // headquarter branch
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  staff     UserBranchAssignment[]
  inventory InventoryItem[]
  orders    Order[]

  @@schema("identity")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER BRANCH ASSIGNMENT  — M:N  (a staff member can cover multiple branches)
// pharmacy_admin: assigned to all branches implicitly (no rows needed)
// pharmacy_staff: explicit row per branch
// ─────────────────────────────────────────────────────────────────────────────

model UserBranchAssignment {
  id         String         @id @default(cuid())
  userId     String
  user       User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  branchId   String
  branch     PharmacyBranch @relation(fields: [branchId], references: [id], onDelete: Cascade)
  isPrimary  Boolean        @default(false) // user's "home" branch
  assignedBy String?        // Firebase UID of who made the assignment
  assignedAt DateTime       @default(now())

  @@unique([userId, branchId])
  @@schema("identity")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER
//
// Roles:
//   system_admin    — platform-wide; tenantId = null
//   pharmacy_admin  — manages all branches under their Tenant; tenantId set
//   pharmacy_staff  — assigned to specific branch(es); tenantId set
//   customer        — no tenant; no branch
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  firebaseUid  String   @unique
  email        String?
  phone        String?
  firstName    String?
  lastName     String?

  // SCOPE classifier — drives multi-tenancy guards.
  // Values: system_admin | pharmacy_admin | pharmacy_staff | customer
  role         String

  // PERMISSION bundle — optional FK to a Role row (custom or system).
  // When null, the user falls back to DEFAULT_PERMISSIONS for their `role`.
  // The Role.scope must be compatible with the user's `role` string.
  roleId       String?
  roleRef      Role?    @relation(fields: [roleId], references: [id])

  tenantId     String?
  tenant       Tenant?  @relation(fields: [tenantId], references: [id])

  isActive     Boolean  @default(true)

  // Profile fields (from ER diagram)
  nic          String?  @unique
  birthday     DateTime?
  gender       String?  // MALE | FEMALE | OTHER
  height       Float?   // cm
  weight       Float?   // kg
  addressLine1 String?
  addressLine2 String?
  addressLine3 String?
  district     String?
  postalCode   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branchAssignments UserBranchAssignment[]
  orders            Order[]
  prescriptions     Prescription[]
  diseases          DiseaseUserMapping[]

  @@schema("identity")
}

// ─────────────────────────────────────────────────────────────────────────────
// MEDICINE  — global formulary (platform-wide, not per-tenant)
// ─────────────────────────────────────────────────────────────────────────────

model Medicine {
  id             String          @id @default(cuid())
  genericName    String
  brandName      String?
  nmraCode       String?         @unique
  form           String
  strength       String?
  unit           String
  isControlled   Boolean         @default(false)
  isHighAlert    Boolean         @default(false)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  inventoryItems InventoryItem[]

  @@schema("catalog")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVENTORY ITEM  — stock at a specific branch
// ─────────────────────────────────────────────────────────────────────────────

model InventoryItem {
  id             String         @id @default(cuid())
  tenantId       String
  branchId       String
  branch         PharmacyBranch @relation(fields: [branchId], references: [id])
  medicineId     String
  medicine       Medicine       @relation(fields: [medicineId], references: [id])
  batchNo        String?
  expiryDate     DateTime?
  quantityOnHand Int            @default(0)
  reorderLevel   Int            @default(10)
  unitPrice      Decimal        @db.Decimal(10, 2)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@schema("ops")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRESCRIPTION
// ─────────────────────────────────────────────────────────────────────────────

model Prescription {
  id             String    @id @default(cuid())
  tenantId       String
  branchId       String
  customerId     String
  customer       User      @relation(fields: [customerId], references: [id])
  imageS3Key     String
  status         String
  ocrRawText     String?
  ocrResult      Json?
  confidenceTier String?
  reviewedBy     String?   // Firebase UID of reviewing pharmacist
  reviewedAt     DateTime?
  reviewNotes    String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  order          Order?

  @@schema("ops")
}

// ─────────────────────────────────────────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────────────────────────────────────────

model Order {
  id                 String         @id @default(cuid())
  tenantId           String
  branchId           String
  branch             PharmacyBranch @relation(fields: [branchId], references: [id])
  customerId         String
  customer           User           @relation(fields: [customerId], references: [id])
  prescriptionId     String?        @unique
  prescription       Prescription?  @relation(fields: [prescriptionId], references: [id])
  status             String
  subtotal           Decimal        @db.Decimal(10, 2)
  deliveryFee        Decimal        @default(0) @db.Decimal(10, 2)
  total              Decimal        @db.Decimal(10, 2)
  currency           String         @default("LKR")
  deliveryAddress    Json?
  deliveryProvider   String?
  deliveryTrackingId String?
  deliveryStatus     String?
  paymentId          String?        @unique
  createdAt          DateTime       @default(now())
  updatedAt          DateTime       @updatedAt

  items   OrderItem[]
  payment Payment?

  @@schema("ops")
}

model OrderItem {
  id           String   @id @default(cuid())
  tenantId     String
  orderId      String
  order        Order    @relation(fields: [orderId], references: [id])
  medicineId   String
  medicineName String
  quantity     Int
  unitPrice    Decimal  @db.Decimal(10, 2)
  total        Decimal  @db.Decimal(10, 2)
  createdAt    DateTime @default(now())

  @@schema("ops")
}

// ─────────────────────────────────────────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────────────────────────────────────────

model Payment {
  id                String    @id @default(cuid())
  tenantId          String
  orderId           String    @unique
  order             Order     @relation(fields: [orderId], references: [id])
  provider          String
  providerOrderId   String?
  providerPaymentId String?
  amount            Decimal   @db.Decimal(10, 2)
  currency          String    @default("LKR")
  status            String
  authorizedAt      DateTime?
  capturedAt        DateTime?
  metadata          Json?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@schema("billing")
}

// ─────────────────────────────────────────────────────────────────────────────
// PERMISSION SYSTEM
//
// UserTypePermission  — default permissions per role (seeded)
// UserPermissionOverride — per-user overrides (optional; future-proof)
// ─────────────────────────────────────────────────────────────────────────────

model ScreenPermission {
  id               String               @id @default(cuid())
  permissionCode   String               @unique
  screenName       String
  description      String?
  category         String?              // group permissions in the UI (e.g. "Inventory", "Billing")
  createdAt        DateTime             @default(now())

  userTypeMappings UserTypePermission[]
  userOverrides    UserPermissionOverride[]
  rolePermissions  RolePermission[]
  menuItems        MenuItem[]

  @@schema("identity")
}

// ─────────────────────────────────────────────────────────────────────────────
// MENU ITEM  — the navigable menu tree.
//
// Exactly two levels of nesting, then a screen:
//   parent  → e.g. "Inventory"            (top-level group; no permission, no route)
//   child   → e.g. "Stock Management"      (sub-group under a parent; no permission, no route)
//   screen  → e.g. "Goods Receive Note"    (leaf; has a route + links to a ScreenPermission)
//
// Visibility rule (resolved in /me/menu):
//   • A `screen` is visible if the user holds its linked permission.
//   • A `child`/`parent` is visible only if it has at least one visible descendant
//     screen — empty branches are pruned from the sidebar.
//
// Menu items are PLATFORM-WIDE (no tenantId). What a user sees is driven entirely
// by their resolved permissions, not by tenant ownership.
// ─────────────────────────────────────────────────────────────────────────────

model MenuItem {
  id           String   @id @default(cuid())
  // parent | child | screen
  type         String
  label        String
  icon         String?  // lucide-react icon name, used by parent/child for the sidebar
  // Self-referencing tree. parent → null; child → a parent's id; screen → a child's id.
  parentId     String?
  parent       MenuItem?  @relation("MenuTree", fields: [parentId], references: [id], onDelete: Cascade)
  children     MenuItem[] @relation("MenuTree")
  // Route is only meaningful for `screen` rows (e.g. "/inventory/grn").
  route        String?
  // Permission gate — only `screen` rows carry this. Null for parent/child.
  permissionId String?
  permission   ScreenPermission? @relation(fields: [permissionId], references: [id], onDelete: SetNull)
  // Ordering within the same parent.
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([parentId])
  @@index([type])
  @@schema("identity")
}

// ─────────────────────────────────────────────────────────────────────────────
// ROLE  — a named bundle of ScreenPermissions assigned to users.
//
// Two flavours:
//   • System roles (isSystem=true, tenantId=null) — seeded:
//     system_admin, pharmacy_admin, pharmacy_staff, customer.
//     Cannot be deleted; permissions can be edited only by system_admin.
//   • Tenant roles (isSystem=false, tenantId set) — created by pharmacy_admin
//     for their own staff. e.g. "Cashier", "Pharmacist", "Inventory Manager".
//
// `scope` constrains which user role-strings can hold this Role:
//   system  → user.role must be system_admin
//   tenant  → user.role must be pharmacy_admin
//   branch  → user.role must be pharmacy_staff
//   customer→ user.role must be customer
// ─────────────────────────────────────────────────────────────────────────────

model Role {
  id          String   @id @default(cuid())
  name        String
  description String?
  // system | tenant | branch | customer
  scope       String
  isSystem    Boolean  @default(false)
  // null for system roles; set for tenant-owned custom roles
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  isActive    Boolean  @default(true)
  createdBy   String?  // Firebase UID of admin who created the role
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  permissions RolePermission[]
  users       User[]

  // Names are unique per tenant scope; system roles share the global namespace (tenantId IS NULL)
  @@unique([tenantId, name])
  @@index([scope])
  @@index([tenantId])
  @@schema("identity")
}

// Join table: which ScreenPermissions are granted by a Role.
model RolePermission {
  id           String           @id @default(cuid())
  roleId       String
  role         Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId String
  permission   ScreenPermission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime         @default(now())

  @@unique([roleId, permissionId])
  @@schema("identity")
}

model UserTypePermission {
  id           String           @id @default(cuid())
  // system_admin | pharmacy_admin | pharmacy_staff | customer
  userTypeCode String
  permissionId String
  permission   ScreenPermission @relation(fields: [permissionId], references: [id])
  isEnabled    Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userTypeCode, permissionId])
  @@schema("identity")
}

// Per-user permission override — allows granting or revoking
// specific permissions for a single user without changing the role defaults.
model UserPermissionOverride {
  id           String           @id @default(cuid())
  userId       String
  permissionId String
  permission   ScreenPermission @relation(fields: [permissionId], references: [id])
  isGranted    Boolean          // true = force-grant, false = force-revoke
  grantedBy    String?          // Firebase UID of admin who set this
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@unique([userId, permissionId])
  @@schema("identity")
}

// ─────────────────────────────────────────────────────────────────────────────
// AUDIT LOG  — healthcare compliance; append-only
// ─────────────────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorUid   String   // Firebase UID of who performed the action
  actorRole  String
  tenantId   String?
  branchId   String?
  action     String   // USER_CREATED | BRANCH_CREATED | PERMISSION_CHANGED | etc.
  entityType String   // User | Tenant | PharmacyBranch | Permission
  entityId   String
  before     Json?
  after      Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@schema("audit")
}

// ─────────────────────────────────────────────────────────────────────────────
// DISEASE TRACKING  (from ER diagram)
// ─────────────────────────────────────────────────────────────────────────────

model DiseaseDetail {
  id          String               @id @default(cuid())
  diseaseCode String               @unique
  diseaseName String

  users       DiseaseUserMapping[]

  @@schema("ops")
}

model DiseaseUserMapping {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  diseaseId String
  disease   DiseaseDetail @relation(fields: [diseaseId], references: [id])
  createdAt DateTime      @default(now())

  @@unique([userId, diseaseId])
  @@schema("ops")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT OWNER  — the pharmacist or company director who legally owns the tenant
// ─────────────────────────────────────────────────────────────────────────────

model TenantOwner {
  id           String   @id @default(cuid())
  tenantId     String   @unique
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  fullName     String
  nic          String?  // National Identity Card No
  phone        String?
  email        String?
  slmcRegNo    String?  // Sri Lanka Medical Council registration
  qualification String?
  addressLine1 String?
  addressLine2 String?
  city         String?
  district     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@schema("identity")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT CONTACTS  — additional contacts (accountant, manager, etc.)
// ─────────────────────────────────────────────────────────────────────────────

model TenantContact {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactType String   // primary | billing | technical | emergency
  name        String
  designation String?
  phone       String?
  email       String?
  isPrimary   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@schema("identity")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT DOCUMENTS  — license scans, certificates, registrations
// ─────────────────────────────────────────────────────────────────────────────

model TenantDocument {
  id           String    @id @default(cuid())
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documentType String    // business_registration | pharmacy_license | nmra_certificate | tax_certificate | insurance | other
  title        String
  fileUrl      String    // S3 URL
  fileSize     Int?      // bytes
  mimeType     String?
  expiryDate   DateTime?
  notes        String?
  uploadedBy   String?   // Firebase UID
  isActive     Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@schema("identity")
}
